{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "vedantu-talent-desk",
  "main": "src/worker.js",
  "compatibility_date": "2026-05-22",
  "workers_dev": true,
  "keep_vars": true,
  "vars": {
    "AUTH_MODE": "workspace-sso",
    "ALLOW_LOCAL_SOURCE_SYNC": "false",
    "AI_MODEL": "gpt-5-nano",
    "AI_SEARCH_MODEL": "gpt-5-nano",
    "AI_QUEUE_SIZE": "250",
    "AI_BATCH_SIZE": "50",
    "AI_MIN_SUBMIT_SIZE": "20",
    "AI_PREPARE_PER_RUN": "20",
    "AI_INGEST_PER_RUN": "25",
    "APPS_SCRIPT_CONNECTOR_URL": "https://script.google.com/macros/s/AKfycbxf5P8wKAcuq7C5LwX13-9vLuxPBhSYnADg5FqdZ4Y06SZRBoM3SrN1LoaRUYdm4xxJ/exec",
    "ACCESS_TEAM_DOMAIN": "abrar-ahmed-778.cloudflareaccess.com",
    "ACCESS_AUD": "66b9592190ccb536075375759be6a8e13d9c5d980020164ad0baee0e2e6da188"
  },
  "ai": {
    "binding": "AI"
  },
  "assets": {
    "directory": "public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "vedantu_talent_desk_db",
      "database_id": "4d9b666b-9875-42c1-be3b-5a952b0368bd",
      "migrations_dir": "migrations"
    }
  ],
  "observability": {
    "enabled": true
  },
  "triggers": {
    "crons": ["* * * * *"]
  }
}
